{
	"layer": "top",
	"position": "bottom",
		"modules-left": ["sway/workspaces"],
		"modules-center": [""],
		"modules-right": ["network", "memory", "disk", "cpu", "clock"],
		"network": {
			"interval": 1,
			"infterface": "enp0s3",
			"format-ethernet": "Down: {bandwidthDownBits} Up: {bandwidthUpBits}",
		},
		"memory": {
			"interval": 1,
			"format": "{used:0.1f}G/{total:0.1f}G"
		},
		"disk": {
			"interval": 30,
			"format": "{free}"
		},
		"cpu": {
			"interval": 1,
			"format": "{usage}%"
		},
		"clock": {
			"format": "{:%H:%M  %d.%m.%Y}"
		}
}
